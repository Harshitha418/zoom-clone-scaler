# Comma-separated list of allowed origins for CORS.
# In production set this to your Vercel URL (e.g. https://your-app.vercel.app).
CORS_ORIGINS=http://localhost:3000

# Base URL used when building invite links (see /join?id=…).
# In production set this to your Vercel URL.
FRONTEND_BASE_URL=http://localhost:3000

# SQLite DB URL. Default is fine locally.
# On Railway with a Volume mounted at /data, use: sqlite:////data/zoom_clone.db
DATABASE_URL=sqlite:///./zoom_clone.db

# Auth — MUST be replaced with a strong random string in any real deployment.
# Generate one with: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-insecure-secret-change-me
JWT_EXPIRE_MINUTES=1440
